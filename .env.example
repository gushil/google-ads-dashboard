# ── Google Ads API (OAuth) ──────────────────────────────────────────────
# Generate refresh token once via Google's OAuth flow; the rest come from your
# Google Cloud project + Google Ads account.
GADS_DEVELOPER_TOKEN=
GADS_CLIENT_ID=
GADS_CLIENT_SECRET=
GADS_REFRESH_TOKEN=
GADS_LOGIN_CUSTOMER_ID=     # MCC/manager account ID, digits only (optional)
GADS_CUSTOMER_ID=           # the ad account to report on, digits only

# ── Google Sheets ───────────────────────────────────────────────────────
SHEET_ID=                   # the long ID in the Sheet URL
# Service account: either point to a file OR paste raw JSON into GOOGLE_SA_JSON.
GOOGLE_SA_FILE=service_account.json
# GOOGLE_SA_JSON={"type":"service_account",...}   # preferred for CI
# NOTE: share the Sheet with the service account's client_email (Editor).

# ── Anthropic ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6   # or claude-opus-4-8 for deepest analysis

# ── Email delivery (SMTP) ───────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=paid-media-bot@openclinica.com
MAIL_TO=person1@openclinica.com,person2@openclinica.com

# ── Business targets ────────────────────────────────────────────────────
TARGET_CPA_USD=150          # your target cost per demo/qualified lead
TARGET_ROAS=0               # set if you track revenue; 0 = not tracked
CURRENCY=USD

# DRY_RUN=true              # render + write sheet but skip the email send
